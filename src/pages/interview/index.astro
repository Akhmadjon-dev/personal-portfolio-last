---
import Layout from '../../layouts/Layout.astro';
import DevPrepApp from '../../components/interview/DevPrepApp';
import { DATA } from '../../data/interview/en';
import { getDict } from '../../i18n/utils';

const t = getDict('en');
const labels = t.interview;
---

<Layout title={t.interview.title} locale="en">
  <DevPrepApp client:load data={DATA} labels={labels} storageKey="devprep:en:completed" />
</Layout>
