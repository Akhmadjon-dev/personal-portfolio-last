---
import { getDict, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);
---

<section id="experience" class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <div class="mb-12 md:mb-16 max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">{t.experience.eyebrow}</p>
    <h2 class="font-display text-4xl md:text-5xl tracking-tight">{t.experience.title}</h2>
  </div>

  <ol class="relative border-l border-mist dark:border-white/10 ml-3 md:ml-5">
    {t.experience.items.map((item: { company: string; role: string; period: string; location: string; summary: string }, idx: number) => (
      <li class={`relative pl-8 md:pl-10 ${idx === 0 ? '' : 'mt-10'}`}>
        <span class="absolute -left-[7px] top-2 w-3 h-3 rounded-full bg-accent ring-4 ring-paper dark:ring-[#0F0F10]"></span>
        <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 md:gap-6">
          <h3 class="font-display text-2xl tracking-tight">
            {item.role} <span class="text-muted font-sans text-lg">— {item.company}</span>
          </h3>
          <span class="font-mono text-xs uppercase tracking-widest text-muted">{item.period}</span>
        </div>
        <p class="font-mono text-[11px] uppercase tracking-widest text-accent mt-1 mb-3">{item.location}</p>
        <p class="text-muted leading-relaxed max-w-3xl">{item.summary}</p>
      </li>
    ))}
  </ol>
</section>
