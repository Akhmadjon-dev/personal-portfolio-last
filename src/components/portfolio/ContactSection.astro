---
import { getDict, type Locale } from '../../i18n/utils';
import ContactForm from './ContactForm';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);

const accessKey = '902f81ab-1644-411b-a83d-0213348fcde9';
---

<section id="contact" class="max-w-6xl mx-auto px-6 py-20 md:py-28">
  <div class="grid md:grid-cols-[1fr_1.2fr] gap-12 md:gap-16">
    <div>
      <p class="font-mono text-xs uppercase tracking-widest text-accent mb-3">{t.contact.eyebrow}</p>
      <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-6">{t.contact.title}</h2>
      <p class="text-lg text-muted leading-relaxed mb-10">{t.contact.body}</p>

      <ul class="space-y-5 text-sm">
        <li>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted mb-1">{t.contact.or_email}</p>
          <a href={`mailto:${t.contact.email_address}`} class="text-base hover:text-accent transition-colors">
            {t.contact.email_address}
          </a>
        </li>
        <li>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted mb-1">{t.contact.phone_label}</p>
          <a href="tel:+998971299777" class="block text-base hover:text-accent transition-colors">+998 97 129 97 77</a>
          <a href="tel:+998995578799" class="block text-base hover:text-accent transition-colors">+998 99 557 87 99</a>
        </li>
        <li>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted mb-1">{t.contact.telegram_label}</p>
          <a href="https://t.me/Akhmadjon_dev" target="_blank" rel="noopener" class="text-base hover:text-accent transition-colors">
            @Akhmadjon_dev
          </a>
        </li>
        <li>
          <p class="font-mono text-[11px] uppercase tracking-widest text-muted mb-1">{t.contact.location_label}</p>
          <p class="text-base">{t.contact.location}</p>
        </li>
      </ul>
    </div>

    <div>
      <ContactForm
        client:visible
        accessKey={accessKey}
        labels={{
          fields: t.contact.fields,
          send: t.contact.send,
          sending: t.contact.sending,
          success_title: t.contact.success_title,
          success_body: t.contact.success_body,
          error_title: t.contact.error_title,
          error_body: t.contact.error_body,
        }}
      />
    </div>
  </div>
</section>
