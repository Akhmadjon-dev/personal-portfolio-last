---
import Layout from '../../../layouts/Layout.astro';
import DevPrepApp from '../../../components/interview/DevPrepApp';
import { DATA } from '../../../data/interview/en';
import { getDict } from '../../../i18n/utils';

const t = getDict('ru');
const labels = t.interview;
---

<Layout title={t.interview.title} locale="ru">
  <DevPrepApp client:load data={DATA} labels={labels} storageKey="devprep:ru:completed" />
</Layout>
