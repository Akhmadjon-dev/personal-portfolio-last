---
import { getDict, localizePath, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);
---

<section class="max-w-6xl mx-auto px-6 pt-20 pb-16 md:pt-32 md:pb-24">
  <p class="font-mono text-xs uppercase tracking-widest text-accent mb-6">{t.hero.eyebrow}</p>
  <h1 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight max-w-4xl">
    {t.hero.headline}
  </h1>
  <p class="mt-8 text-lg md:text-xl text-muted max-w-2xl">
    {t.hero.subline}
  </p>
  <div class="mt-10 flex flex-wrap gap-4">
    <a
      href={localizePath('/#contact', locale)}
      class="inline-flex items-center px-6 py-3 rounded-full bg-ink text-paper dark:bg-paper dark:text-ink font-medium hover:opacity-90 transition-opacity"
    >
      {t.hero.cta_hire} →
    </a>
    <a
      href="/cv.pdf"
      class="inline-flex items-center px-6 py-3 rounded-full border border-ink/20 dark:border-white/20 hover:bg-paper-dim dark:hover:bg-white/5 transition-colors"
    >
      {t.hero.cta_cv}
    </a>
  </div>
</section>

<section id="tools" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="font-display text-3xl md:text-4xl mb-10">{t.what_i_do.title}</h2>
  <div class="grid md:grid-cols-3 gap-6">
    {(['web', 'ai', 'mobile'] as const).map((k) => (
      <div class="p-6 rounded-[var(--radius-card)] border border-mist dark:border-white/10 bg-paper dark:bg-white/[0.02]">
        <h3 class="font-display text-2xl mb-2">{t.what_i_do.items[k].title}</h3>
        <p class="text-muted">{t.what_i_do.items[k].body}</p>
      </div>
    ))}
  </div>
</section>

<section id="projects" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="font-display text-3xl md:text-4xl mb-2">{t.projects.title}</h2>
  <p class="text-muted mb-10">{t.projects.subtitle}</p>
  <div class="grid md:grid-cols-2 gap-6">
    <a href={localizePath('/french', locale)} class="group p-6 rounded-[var(--radius-card)] border border-mist dark:border-white/10 hover:border-accent transition-colors">
      <div class="font-mono text-xs text-accent mb-3">TOOL</div>
      <h3 class="font-display text-2xl mb-2 group-hover:text-accent transition-colors">{t.tools.french.title} →</h3>
      <p class="text-muted">{t.tools.french.body}</p>
    </a>
    <a href={localizePath('/interview', locale)} class="group p-6 rounded-[var(--radius-card)] border border-mist dark:border-white/10 hover:border-accent transition-colors">
      <div class="font-mono text-xs text-accent mb-3">TOOL</div>
      <h3 class="font-display text-2xl mb-2 group-hover:text-accent transition-colors">{t.tools.interview.title} →</h3>
      <p class="text-muted">{t.tools.interview.body}</p>
    </a>
  </div>
</section>

<section id="about" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="font-display text-3xl md:text-4xl mb-6">{t.about.title}</h2>
  <p class="text-lg text-muted max-w-2xl">{t.about.body}</p>
</section>

<section id="contact" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="font-display text-3xl md:text-4xl mb-4">{t.contact.title}</h2>
  <p class="text-muted mb-8">{t.contact.body}</p>
  <a href="mailto:realcodeuz@gmail.com" class="inline-flex items-center px-6 py-3 rounded-full bg-ink text-paper dark:bg-paper dark:text-ink font-medium">
    realcodeuz@gmail.com
  </a>
</section>
