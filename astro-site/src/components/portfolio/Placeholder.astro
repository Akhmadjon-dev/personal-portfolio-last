---
import { type Locale, localizePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  note: string;
}

const { locale, title, note } = Astro.props;
---

<section class="max-w-4xl mx-auto px-6 py-32">
  <p class="font-mono text-xs uppercase tracking-widest text-accent mb-6">Coming soon</p>
  <h1 class="font-display text-5xl md:text-6xl leading-[1.05] tracking-tight mb-6">{title}</h1>
  <p class="text-lg text-muted mb-10 max-w-2xl">{note}</p>
  <a
    href={localizePath('/', locale)}
    class="inline-flex items-center text-accent hover:underline"
  >
    ← Back home
  </a>
</section>
