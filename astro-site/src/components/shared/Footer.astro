---
import { getDict, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-mist dark:border-white/5 mt-12">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <div class="text-sm">© {year} Ahmadjon Abdusamadov</div>
      <div class="text-xs text-muted mt-1">{t.footer.tagline}</div>
    </div>
    <div class="flex items-center gap-5 text-sm">
      <a href="https://github.com/Akhmadjon-dev" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper transition-colors">GitHub</a>
      <a href="https://www.linkedin.com/in/akhmadjonabdusamdov/" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper transition-colors">LinkedIn</a>
      <a href="https://t.me/Akhmadjon_dev" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper transition-colors">Telegram</a>
      <a href={`mailto:info.ahmadjon@gmail.com`} class="text-muted hover:text-ink dark:hover:text-paper transition-colors">Email</a>
    </div>
    <div class="text-xs text-muted font-mono">{t.footer.built}</div>
  </div>
</footer>
