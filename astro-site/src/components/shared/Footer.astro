---
import { getDict, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-mist dark:border-white/5 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="text-sm text-muted">
      © {year} Ahmadjon Abdusamadov
    </div>
    <div class="flex items-center gap-5 text-sm">
      <a href="https://github.com/" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper">GitHub</a>
      <a href="https://linkedin.com/" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper">LinkedIn</a>
      <a href="https://t.me/" target="_blank" rel="noopener" class="text-muted hover:text-ink dark:hover:text-paper">Telegram</a>
    </div>
    <div class="text-xs text-muted font-mono">{t.footer.built}</div>
  </div>
</footer>
